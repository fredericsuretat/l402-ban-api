# --- Choisir UN des deux modes ---
# Mode managé (zéro config, 0,3% de frais) : ta Lightning address (Alby, Strike, Blink, WoS…)
LIGHTNING_ADDRESS=toi@getalby.com
# Mode direct Alby (0% frais kit) : token API Alby
#ALBY_TOKEN=

# Prix par requête en satoshis
PRICE_SATS=5

# Géocodeur BAN (Géoplateforme IGN par défaut ; ancien: https://api-adresse.data.gouv.fr)
BAN_BASE_URL=https://data.geopf.fr/geocodage

PORT=3402

# --- Dashboard wallet privé (optionnel) ---
# Connexion NWC lecture seule créée dans Alby (Connections → Add connection → permissions: read balance + transactions)
#NWC_URL=nostr+walletconnect://...
# Token d'accès au dashboard : openssl rand -hex 24
#DASHBOARD_TOKEN=
